# MarketingOS environment variables.
# Copy to .env and fill in. Never commit the filled-in .env.
#
# The API loads this file automatically on startup (see
# marketingos.api.dependencies), so the running backend picks up whatever you
# put here — you do NOT need to export these in your shell. A variable already
# set in the real environment still takes precedence over this file.

# Google Generative Language API key, used by
# marketingos.tools.llm.gemini_client.GeminiClient for text generation.
# Create one at https://aistudio.google.com/apikey — the free tier is
# sufficient for the pilot.
#
# IMPORTANT: a real API key starts with "AIzaSy" and is ~39 characters. A value
# starting with "AQ." is an *ephemeral* Live-API token that expires within about
# an hour and will fail later runs with 403 PERMISSION_DENIED — do not use it.
GEMINI_API_KEY=

# Together AI API key, used by
# marketingos.tools.image.flux_schnell_client.FluxSchnellClient for image
# generation (FLUX.1 [schnell]). Only required when config/models.yaml sets
# image_provider: flux_schnell. Create one at
# https://api.together.xyz/settings/api-keys — the FLUX.1-schnell-Free endpoint
# is free tier.
TOGETHER_API_KEY=

# Optional. Comma-separated frontend origins allowed to call the API via CORS
# (e.g. your deployed frontend URL). Empty by default, which fails closed.
# Local dev needs nothing here — the Vite dev server proxies /api to the backend.
# ALLOWED_ORIGINS=https://your-frontend.example

# Optional. Where run artifacts (state, eval reports, packages) are written.
# Defaults to data/runs relative to the working directory.
# RUNS_ROOT=data/runs

# Optional. Port for the `marketingos` console-script entrypoint. Defaults to 8000.
# PORT=8000
